# Supabase тохиргоо. Энэ файлыг .env нэрээр хуулж, өөрийн утгаараа солино.
# Supabase Dashboard -> Project Settings -> API хэсгээс авна.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Царай таних (Luxand.cloud). https://dashboard.luxand.cloud/token -> token авна.
# Байхгүй бол царай бүртгэл (10 удаа) ажиллана ч таних шалгалт хийхгүй (алгасна).
EXPO_PUBLIC_LUXAND_TOKEN=your-luxand-token
