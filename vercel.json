{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd public-web && npm install",
  "buildCommand": "node scripts/build-web.js",
  "outputDirectory": "dist-web",
  "framework": null,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/about", "destination": "/index.html" },
    { "source": "/services", "destination": "/index.html" },
    { "source": "/projects", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" },
    { "source": "/careers", "destination": "/index.html" }
  ]
}
